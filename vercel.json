{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/onboarding", "destination": "/index.html" },
    { "source": "/auth", "destination": "/index.html" },
    { "source": "/dashboard/:path*", "destination": "/index.html" }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.cognitio-plus.com" }],
      "destination": "https://cognitio-plus.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "cognitio-plus.net" }],
      "destination": "https://cognitio-plus.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.cognitio-plus.net" }],
      "destination": "https://cognitio-plus.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "cognitio-plus.appimize.app" }],
      "destination": "https://cognitio-plus.com/:path*",
      "permanent": true
    }
  ]
}
